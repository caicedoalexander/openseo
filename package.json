{
    "name": "openseo",
    "version": "0.1.0",
    "description": "Open-source, AI-native SEO toolkit for WordPress.",
    "license": "GPL-2.0-or-later",
    "private": true,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "format": "wp-scripts format",
        "lint:js": "wp-scripts lint-js",
        "lint:css": "wp-scripts lint-style",
        "lint:php": "composer lint",
        "lint:md": "wp-scripts lint-md-docs",
        "packages-update": "wp-scripts packages-update",
        "plugin-zip": "wp-scripts plugin-zip",
        "test:js": "wp-scripts test-unit-js",
        "env:start": "wp-env start",
        "env:stop": "wp-env stop",
        "env:run": "wp-env run",
        "env:clean": "wp-env clean all",
        "test:integration": "wp-env run tests-cli --env-cwd=wp-content/plugins/openseo vendor/bin/phpunit -c phpunit-integration.xml.dist"
    },
    "devDependencies": {
        "@wordpress/abilities": "^0.14.1",
        "@wordpress/env": "^10.10.0",
        "@wordpress/scripts": "^30.0.0"
    }
}
